\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{dsa2026}

\RequirePackage{fancyhdr}
\RequirePackage{xcolor}
\RequirePackage{titlesec}

\definecolor{dsaGreen}{RGB}{0, 128, 0}

% Title command
\newcommand{\makeDSATitle}[1]{
    \begin{center}
        {\LARGE \bfseries \color{dsaGreen} #1 \par}
    \end{center}
    \vspace{1em}
}

% Define Footer/Header Commands
\newcommand{\shortauthor}{Author et al.}
\newcommand{\shorttitle}{Title}

% Setup Pagestyle
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}
\fancyhead[R]{\small \itshape DSA Kampala 2026 Workshop}
\fancyfoot[L]{\small \itshape \shortauthor \: -- \: \shorttitle}
\fancyfoot[R]{\thepage}

% This part forces the FIRST PAGE to show the header/footer too
\fancypagestyle{plain}{
  \fancyhf{}
  \fancyhead[R]{\small \itshape DSA 2026 Workshop}
  \fancyfoot[L]{\small \itshape \shortauthor \: -- \: \shorttitle}
  \fancyfoot[R]{\thepage}
}
